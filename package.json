{
  "name": "lexibridge-translate",
  "version": "1.0.0",
  "description": "Chrome extension for user-triggered web translation, vocabulary collection, and exam vocabulary review.",
  "main": "dist/background.js",
  "scripts": {
    "build": "webpack --mode=production",
    "build:dev": "webpack --mode=development",
    "dev": "webpack --mode=development --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.js",
    "lint:fix": "eslint src --ext .ts,.js --fix",
    "type-check": "tsc --noEmit",
    "quality": "npm run lint && npm run type-check && npm run test",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "package": "npm run build && cd dist && powershell Compress-Archive -Path * -DestinationPath ../chrome-translation-extension.zip -Force",
    "release": "npm run quality && npm run package"
  },
  "keywords": [
    "chrome-extension",
    "translation",
    "learning",
    "vocabulary",
    "typescript"
  ],
  "author": "Chrome Translation Extension Team",
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "^0.0.246",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.6.3",
    "@typescript-eslint/eslint-plugin": "^6.7.2",
    "@typescript-eslint/parser": "^6.7.2",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.1",
    "eslint": "^8.49.0",
    "fast-check": "^3.13.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "mini-css-extract-plugin": "^2.7.6",
    "rimraf": "^5.0.1",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.4.4",
    "typescript": "^5.2.2",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@tesseract.js-data/chi_sim": "^1.0.0",
    "@tesseract.js-data/chi_tra": "^1.0.0",
    "@tesseract.js-data/eng": "^1.0.0",
    "@tesseract.js-data/jpn": "^1.0.0",
    "@tesseract.js-data/kor": "^1.0.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.11.174",
    "tesseract.js": "^5.1.1",
    "webextension-polyfill": "^0.10.0"
  }
}
